  "rules": [
    {
      "id": "AC_CLEARANCE_8MM",
      "severity": "error",
      "description": "Maintain at least 8mm clearance and isolation slot between AC primary and low-voltage domains.",
      "applies_to": [
        "J1",
        "F1",
        "MOV1",
        "U6"
      ],
      "net_class": null
    },
    {
      "id": "SPI_LENGTH_MATCH_2MM",
      "severity": "error",
      "description": "SPI traces must be length matched within +/-2mm.",
      "applies_to": [
        "SPI_*"
      ],
      "net_class": null
    },
    {
      "id": "TXB0104_DISTANCE_15MM",
      "severity": "error",
      "description": "Place TXB0104 within 15mm of DWM3000.",
      "applies_to": [
        "U2",
        "U3"
      ],
      "net_class": null
    },
    {
      "id": "RTLS_TRANSLATOR_DISTANCE_10MM",
      "severity": "error",
      "description": "Place IRQ and EXT_TX translators within 10mm of DWM3000 pins.",
      "applies_to": [
        "U2",
        "U4",
        "U5"
      ],
      "net_class": null
    },
    {
      "id": "RELAY_NO_DIRECT_GPIO_DRIVE",
      "severity": "error",
      "description": "Relay coils must not connect directly to ESP32 GPIO. Use optocoupler, MOSFET, and flyback diode.",
      "applies_to": [
        "K1"
      ],
      "net_class": null
    },
    {
      "id": "RF_50R_WIDTH_035MM",
      "severity": "error",
      "description": "RF trace must be 50 ohm controlled impedance with 0.35mm width on specified FR4 stackup.",
      "applies_to": [
        "UWB_RF_50R"
      ],
      "net_class": null
    },
    {
      "id": "RF_NO_VIAS_OR_TESTPOINTS",
      "severity": "error",
      "description": "No vias, test points, or components are allowed on the RF trace.",
      "applies_to": [
        "UWB_RF_50R"
      ],
      "net_class": null
    },
    {
      "id": "RF_KEEP_OUT_3MM",
      "severity": "error",
      "description": "Maintain 3mm RF keepout around antenna trace.",
      "applies_to": [
        "UWB_RF_50R"
      ],
      "net_class": null
    },
    {
      "id": "POWER_RAIL_SEQUENCE",
      "severity": "warning",
      "description": "Validate 5V before 3V3 before 1V8 startup behavior.",
      "applies_to": [
        "+5V_ISO",
        "+3V3",
        "+1V8"
      ],
      "net_class": null
    },
    {
      "id": "HUMAN_REVIEW_REQUIRED",
      "severity": "warning",
      "description": "Human engineer must review AC safety, RF impedance, relay isolation, and final DRC/ERC before fabrication.",
      "applies_to": [
        "ALL"
      ],
      "net_class": null
    }
  ],
